    "wp:windows": "node -e \"fetch('http://localhost:3006/api/wp/npc-windows?render=0&random=1&limit=30').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:features": "node -e \"fetch('http://localhost:3006/api/wp/features?limit=40').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:health": "node -e \"fetch('http://localhost:3006/api/wp/health').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
