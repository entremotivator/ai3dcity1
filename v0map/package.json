{
  "name": "my-v0-project",
  "version": "0.1.286",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "dev:3006": "next dev -p 3006",
    "lint": "next lint",
    "start": "next start",
    "fresh:3006": "rm -rf node_modules .next package-lock.json pnpm-lock.yaml yarn.lock && pnpm install && pnpm exec next dev -p 3006",
