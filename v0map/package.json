    "wp:search": "node -e \"const q=process.argv.slice(1).join(' ')||'bsp_app'; fetch('http://localhost:3006/api/wp/search?q='+encodeURIComponent(q)+'&limit=20').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:render-url": "node -e \"const tag=process.argv[1]||'bsp_app'; fetch('http://localhost:3006/api/wp/render-url?tag='+encodeURIComponent(tag)).then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "voice:commands": "node -e \"fetch('http://localhost:3006/api/local/command').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "team:25": "node -e \"console.log(require('./public/npc-team-25.import.json').npcs.length + ' NPC team preset ready')\"",
    "team:50": "node -e \"console.log(require('./public/npc-team-50.import.json').npcs.length + ' NPC team preset ready')\"",
    "team:100": "node -e \"console.log(require('./public/npc-team-100.import.json').npcs.length + ' NPC team preset ready')\"",
    "wp:voice-commands": "node -e \"fetch('http://localhost:3006/api/wp/voice-commands').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:team-presets": "node -e \"fetch('http://localhost:3006/api/wp/team-presets').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:live-voice": "node -e \"fetch('http://localhost:3006/api/wp/live-voice-options').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:project-templates": "node -e \"fetch('http://localhost:3006/api/wp/project-templates').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "project:import": "node -e \"console.log(require('./public/project-management.import.json').tasks.length + ' project tasks ready')\"",
    "habits:import": "node -e \"console.log(require('./public/habit-tracker.import.json').habits.length + ' habits ready')\"",
    "voice:schema": "node -e \"fetch('http://localhost:3006/api/voice/command-schema').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "voice:parse": "node -e \"const q=process.argv.slice(1).join(' ')||'NPC 1 come here'; fetch('http://localhost:3006/api/voice/parse?q='+encodeURIComponent(q)).then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:voice-suite": "node -e \"fetch('http://localhost:3006/api/wp/voice-command-suite').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:project-suite": "node -e \"fetch('http://localhost:3006/api/wp/project-manager-suite').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "wp:npc-movement": "node -e \"fetch('http://localhost:3006/api/wp/npc-movement-playbook').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "project:sprint": "node -e \"console.log(require('./public/project-sprint-30-day.import.json').tasks.length + ' sprint tasks ready')\"",
    "habits:advanced": "node -e \"console.log(require('./public/habit-tracker-advanced.import.json').habits.length + ' advanced habits ready')\"",
    "npc:movement-playbook": "node -e \"console.log(require('./public/npc-movement-playbook.import.json').moves.length + ' movement commands ready')\"",
    "wp:agent-roster": "node -e \"fetch('http://localhost:3006/api/wp/npc-windows?render=0&random=0&limit=68').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2)))\"",
    "agents:68": "node -e \"const data=require('./public/exact-agent-roster-68.import.json'); console.log(data.agents.length + ' exact agents ready')\"",
    "speed:note": "node -e \"console.log('R3F speed mode is built into the UI: toggle Speed/HQ on the floor dock.')\""
  },
